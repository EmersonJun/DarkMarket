; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Mercado Negro"
config/description="Trading tycoon vertical slice — see ../GDD_Mercado_Paralelo.md"
run/main_scene="res://scenes/Title.tscn"
config/features=PackedStringArray("4.6", "Mobile")
boot_splash/bg_color=Color(0.055, 0.043, 0.094, 1)
boot_splash/show_image=false
config/icon="res://art/icon.svg"

[autoload]

Style="*res://ui/Style.gd"
Audio="*res://scripts/Audio.gd"
GameState="*res://scripts/GameState.gd"
Economy="*res://scripts/Economy.gd"
News="*res://scripts/News.gd"
NPCs="*res://scripts/NPCs.gd"
Employees="*res://scripts/Employees.gd"
Prestige="*res://scripts/Prestige.gd"
Posts="*res://scripts/Posts.gd"
Contracts="*res://scripts/Contracts.gd"
Collection="*res://scripts/Collection.gd"
DailyRewards="*res://scripts/DailyRewards.gd"
SaveSystem="*res://scripts/SaveSystem.gd"

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/size/window_width_override=540
window/size/window_height_override=960
window/stretch/mode="canvas_items"
window/handheld/orientation=1

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="mobile"
2d/snap/snap_2d_transforms_to_pixel=true
